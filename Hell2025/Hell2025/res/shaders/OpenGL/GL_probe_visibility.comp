                 int x = voxelBase.x + dx;
                 int y = voxelBase.y + dy;
                 int z = voxelBase.z + dz;

                int idx = x + (y * u_probeCountX) + (z * u_probeCountX * u_probeCountY);    // Probe idx 1D from xyz

                int baseIdx = idx * 9;
                sh_data[baseIdx].w = 1;

                //if (any(lessThan(idx, ivec3(0))) || any(greaterThanEqual(idx, lightVolumeSize)))
