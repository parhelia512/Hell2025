    return;

    ivec2 pixelCoords = ivec2(gl_GlobalInvocationID.xy);
    ivec2 gBufferSize = textureSize(u_gBufferDepthTexture, 0);

    if (gl_GlobalInvocationID.y > 540 / 8) return;

    // Bounds check
    if (pixelCoords.x >= gBufferSize.x || pixelCoords.y >= gBufferSize.y) return;

    // Sample GBuffer
    vec3 fragmentWorldPos = texelFetch(u_worldPositionTexture, pixelCoords, 0).xyz;
    vec3 fragmentNormal = texelFetch(u_normalTexture, pixelCoords, 0).xyz;

    // Bail if you have no normal, that this pixel is skybox
    if (fragmentNormal == vec3(0.0)) return;

    fragmentNormal = normalize(fragmentNormal);

    // Offset along frag normal so you don't sample inside
    vec3 safefragmentWorldPos = fragmentWorldPos + fragmentNormal * 0.05;

    // Map fragment world pos to grid space
    ivec3 fragmentProbeSpacePosition = ivec3((safefragmentWorldPos - u_probeOffset) / u_probeSpacing);




    // Compute which probes this pixel would sample
    vec3 voxelWorldPos = (fragmentProbeSpacePosition - u_probeOffset) / u_probeSpacing;
    ivec3 voxelBase = ivec3(floor(voxelWorldPos));


    // Mark the eight neighbours
    for (int dz = 0; dz <= 1; dz++) {
        for (int dy = 0; dy <= 1; dy++) {
