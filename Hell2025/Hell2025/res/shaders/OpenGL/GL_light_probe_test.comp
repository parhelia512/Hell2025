#version 450
#include "../common/raytracing.glsl"

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

uniform int u_probeCount;
uniform vec3 u_gridOffset;
uniform float u_spacing;
uniform int u_gridWidth;
uniform int u_gridHeight;
uniform int u_gridDepth;
uniform int u_pointCount;
uniform int u_frameIndex;
uniform float u_pointCloudSpacing;

// SH Constants
const float SH_C0 = 0.28209479177;
const float SH_C1 = 0.4886025119;
const float SH_C2 = 1.09254843059;
const float SH_C3 = 0.31539156525;
const float SH_C4 = 0.54627421529;

// Irradiance Convolution Constants
const float A0 = 3.141592654;       // PI
const float A1 = 2.094395102 * 0.9; // Slightly darkened linear
const float A2 = 0.785398163 * 0.5; // Heavily suppressed quadratic

uint probeStrideControl = 128; // Probe stride control
uint pointStrideControl = 8;   // Point stride control
const float maxDist = 3.0;     // This is the distance in which points influence probes

uint hash(uint x) {
    x = ((x >> 16) ^ x) * 0x45d9f3b;
    x = ((x >> 16) ^ x) * 0x45d9f3b;
    x = (x >> 16) ^ x;
    return x;
}

void main() {
    uint pIdx = gl_GlobalInvocationID.x;
    if (pIdx >= uint(u_probeCount)) return;
    int stride = u_probeCount;

    // Decoupled dither hash to skip entire probes
    uint probeDither = hash(pIdx + (uint(u_frameIndex) * 7193));
    if (probeDither % probeStrideControl != 0) {
        return; // Skip computing this probe entirely this frame
    }

    // Reconstruct probe position
    uint upCount = uint(u_gridWidth * u_gridHeight);
    uint z = pIdx / upCount;
    uint y = (pIdx / uint(u_gridWidth)) % uint(u_gridHeight);
    uint x = pIdx % uint(u_gridWidth);
    vec3 probePos = u_gridOffset + (vec3(float(x), float(y), float(z)) * u_spacing);

    vec3 frame_sh[9];
    for(int i = 0; i < 9; i++) {
        frame_sh[i] = vec3(0.0);
    }

    const float maxDistSq = maxDist * maxDist;
    const float pointArea = u_pointCloudSpacing * u_pointCloudSpacing;

    uint dither = hash(pIdx + uint(u_frameIndex));
    uint safePointStride = max(pointStrideControl, 1u);
    uint startOffset = dither % safePointStride;

    // Interleaved point cloud processing
    for (uint i = startOffset; i < uint(u_pointCount); i += safePointStride) {

        if (dot(points[i].directLighting.xyz, vec3(1.0)) < 0.001) continue;

        vec3 ptPos = points[i].position.xyz;
        vec3 diff = ptPos - probePos;
        float distSq = dot(diff, diff);

        if (distSq > maxDistSq || distSq < 0.0001) continue;

        vec3 ptNormal = points[i].normal.xyz;
        if (dot(ptNormal, -diff) <= 0.0) continue;

        float dist = sqrt(distSq);
        vec3 dirToPoint = diff / dist;

        if (!AnyHit(probePos, dirToPoint, 0.01, dist - 0.01)) {
            float cosTheta = dot(ptNormal, -dirToPoint);

            vec3 outgoingRadiance = points[i].directLighting.xyz;

            float safeDistSq = max(distSq, pointArea);

            // scale energy by stride to compensate for skipped points during temporal accumulation
            float energyMultiplier = float(safePointStride);
            vec3 radiance = (outgoingRadiance * cosTheta * pointArea * energyMultiplier) / safeDistSq;

            float n[9];
            n[0] = SH_C0 * A0;
            n[1] = -SH_C1 * dirToPoint.y * A1;
            n[2] =  SH_C1 * dirToPoint.z * A1;
            n[3] = -SH_C1 * dirToPoint.x * A1;
            n[4] =  SH_C2 * dirToPoint.x * dirToPoint.y * A2;
            n[5] = -SH_C2 * dirToPoint.y * dirToPoint.z * A2;
            n[6] =  SH_C3 * (3.0 * dirToPoint.z * dirToPoint.z - 1.0) * A2;
            n[7] = -SH_C2 * dirToPoint.x * dirToPoint.z * A2;
            n[8] =  SH_C4 * (dirToPoint.x * dirToPoint.x - dirToPoint.y * dirToPoint.y) * A2;

            for(int j = 0; j < 9; j++) {
                frame_sh[j] += radiance * n[j];
            }
        }
    }

    // Temporal Blend
    // If stride is 1, overwrite instantly
    float lerpFactor = (safePointStride == 1u) ? 1.0 : 0.1;
    int baseIdx = int(pIdx) * 9;

    for (int i = 0; i < 9; i++) {
        vec3 old_sh = sh_data[baseIdx + i].rgb;
        vec3 blended = mix(old_sh, frame_sh[i], lerpFactor);

        sh_data[baseIdx + i].rgb = blended;

        // TODO: find out if only writing .rgb vs .rgba is slower or
        // different in any as far as the gpu is concerned
        // sh_data[baseIdx + i] = vec4(blended, 0.0);
    }


}


// Works to write diffuse of light 0 (fireplace) into probes
void main2() {
    uint pIdx = gl_GlobalInvocationID.x;
    if (pIdx >= u_probeCount) return;

    // Reconstruct Probe Position
    uint z = pIdx / (u_gridWidth * u_gridHeight);
    uint y = (pIdx / u_gridWidth) % u_gridHeight;
    uint x = pIdx % u_gridWidth;
    vec3 probePos = u_gridOffset + (vec3(x, y, z) * u_spacing);

    // Get light (fireplace light is index 0)
    Light light = lights[0];
    vec3 lightPosition = vec3(light.posX, light.posY, light.posZ);
    vec3 lightColor = vec3(light.colorR, light.colorG, light.colorB);

    // Direction and Attenuation
    vec3 dirToLight = lightPosition - probePos;
    float dist = length(dirToLight);
    vec3 lightDir = normalize(dirToLight);

    float attenuation = light.strength / (dist * dist + 1.0);
    attenuation *= clamp(1.0 - (dist / light.radius), 0.0, 1.0);
    vec3 radiance = lightColor * attenuation;

    // SH Projection
    const float A0 = 3.141592654;
    const float A1 = 2.094395102 * 0.9;
    const float A2 = 0.785398163 * 0.5;

    float n[9];
    n[0] = SH_C0 * A0;
    n[1] = -SH_C1 * lightDir.y * A1;
    n[2] =  SH_C1 * lightDir.z * A1;
    n[3] = -SH_C1 * lightDir.x * A1;
    n[4] =  SH_C2 * lightDir.x * lightDir.y * A2;
    n[5] = -SH_C2 * lightDir.y * lightDir.z * A2;
    n[6] =  SH_C3 * (3.0 * lightDir.z * lightDir.z - 1.0) * A2;
    n[7] = -SH_C2 * lightDir.x * lightDir.z * A2;
    n[8] =  SH_C4 * (lightDir.x * lightDir.x - lightDir.y * lightDir.y) * A2;

    // Write coalesced vec4
    int baseIdx = int(pIdx) * 9;
    for (int i = 0; i < 9; i++) {
        sh_data[baseIdx + i].xyz = vec3(radiance * n[i]);

        // TODO: find out if only writing .rgb vs .rgba is slower or
        // different in any as far as the gpu is concerned
        // sh_data[baseIdx + i] = vec4(radiance * n[i], 0.0);
    }
}
